<?xml version="1.0" encoding="UTF-8"?>
<Configuration ID="ORG-M365-SemiAnnual">

  <!--
    Your Organization - M365 Apps for Enterprise
    Channel : Semi-Annual Enterprise Channel
    Products: O365ProPlusRetail
    Author  : Your Name - IT Solutions Architecture
    Version : 1.0 | 2026-06-02
  -->

  <!--
    No SourcePath set: setup.exe resolves Office\Data relative to its working
    directory. This makes the config portable across the build server (E:\Build\...)
    and the reference VM (C:\AuditMode\...) without path conflicts. Both the
    download helper and the installer set -WorkingDirectory to the ODT folder.
    With AllowCdnFallback=FALSE the source MUST be present locally. Pre-download
    once with
    Download-OfficeSource.ps1 on the build server, then rebuild the ISO (06 + 07) -
    install in audit mode. See STAGED-OFFICE-VERSION.txt for the staged build.
    REVIEW: refresh the source roughly every 6 months (SAEC feature updates land
    ~January and ~July) and re-verify the Acrobat build at the same time.
  -->
  <Add OfficeClientEdition="64"
       Channel="SemiAnnual"
       AllowCdnFallback="FALSE"
       ForceUpgrade="TRUE">

    <!--
      OneDrive and Teams are INTENTIONALLY INCLUDED here (not excluded).
      The offline build (script 06) removes the pre-installed CONSUMER/inbox
      OneDriveSetup.exe stub, and the Lists/ApprovedRemoval-Apps.txt removal
      list strips the CONSUMER Teams personal app + legacy inbox MSTeams app -
      those are the clients that caused repeated deployment failures
      (personal-account prompts, stale tenant cache, double icons) and forced
      manual uninstall/reinstall by the support team.
      What ODT installs here is different: the ENTERPRISE OneDrive for
      Business and Teams (work) clients, signed in to the ORG tenant, as part
      of the same M365 Apps install as Word/Excel/etc. Excluding them from
      ODT would just mean no OneDrive/Teams client at all until the
      deployment team installs one separately - it would not prevent the
      support-ticket-causing consumer clients, since those never came from
      ODT in the first place. See script 06 and Lists/ApprovedRemoval-Apps.txt
      for the offline side of this split.
    -->
    <Product ID="O365ProPlusRetail">
      <Language ID="en-us" />
      <ExcludeApp ID="Access" />
      <ExcludeApp ID="Groove" />
      <ExcludeApp ID="Lync" />
      <ExcludeApp ID="Publisher" />
    </Product>

  </Add>

  <!-- Block Office from auto-updating during image build / audit mode -->
  <Updates Enabled="FALSE"
           Channel="SemiAnnual" />

  <Display Level="None" AcceptEULA="TRUE" />

  <Logging Level="Standard" Path="C:\Windows\Temp\ODT_Install.log" />

  <Property Name="AUTOACTIVATE" Value="0" />
  <Property Name="FORCEAPPSHUTDOWN" Value="TRUE" />
  <Property Name="SharedComputerLicensing" Value="0" />
  <Property Name="PinIconsToTaskbar" Value="FALSE" />

  <RemoveMSI />

  <AppSettings>
    <User Key="software\microsoft\office\16.0\common\general"
          Name="shownfirstrunoptin"
          Value="1"
          Type="REG_DWORD"
          App="office16"
          Id="L_DisableOptinWizard" />
    <User Key="software\microsoft\office\16.0\firstrun"
          Name="disablemovie"
          Value="1"
          Type="REG_DWORD"
          App="office16"
          Id="L_DisableMovie" />
  </AppSettings>

</Configuration>
